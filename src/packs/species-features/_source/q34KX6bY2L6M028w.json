  "system": {
    "description": {
      "value": "<p>A Skunk can use an action to emit a fetid spray in a straight line for 10 feet.Each creature in this line must make a Dexterity saving throw with DC 8 + your Constitution bonus + your proficiency bonus. If they fail this saving throw, a sprayed creature becomes poisoned for one minute and a disgusting rotten smell persists on its body for up to a week, causing their presence to be smelled from up to 60 feet in the right wind conditions.</p>",
      "chat": "",
      "unidentified": ""
    },
