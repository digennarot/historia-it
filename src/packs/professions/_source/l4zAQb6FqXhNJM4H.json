  "system": {
    "description": {
      "value": "<p><span class=\"fontstyle0\">Ascetics are followers of a particular philosophy within the sect called the Heresy of the Iron Hand. As sinister as it is extreme, its disciples condemn themselves to eternal torment by gradually covering themselves with plates of hooked metal riveted to their own flesh, starting from their hands. Frightening in the eyes of others and constantly in pain, the Ascetics reach the heights of mysticism possible for the flagellant.</span></p>",
      "chat": "",
      "unidentified": ""
    },
