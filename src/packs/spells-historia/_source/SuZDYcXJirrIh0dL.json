{
  "name": "Decompose",
  "type": "spell",
  "img": "icons/magic/death/projectile-skull-fire-orange.webp",
  "system": {
    "description": {
      "value": "<p><span style=\"font-family:'Helvetica Neue', Helvetica, Arial, sans-serif\">You reach out and touch the corpse of a creature. Over the next minute, the corpse begins to rapidly decompose, sprouting fungus and moss as it begins to degrade into compost and mulch. An odd-colored flower or two may also spring from the corpse in this time. Applicable requirements for resurrection are unaffected by this decomposition.</span></p>",
