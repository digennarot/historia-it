  "system": {
    "description": {
      "value": "<p><span class=\"fontstyle0\">When you gain access to this universal mystery, you can spend 10 Enchantment Points to ignite your own burning </span><span class=\"fontstyle0\">soul, which manifests in flames that surround you. You gains the following benefits for a minute:</span></p>\n<ul>\n<li><span class=\"fontstyle0\">Fire Immunity.</span></li>\n<li><span class=\"fontstyle0\">You can double the damage inflicted with Play with Fire </span><span class=\"fontstyle0\">and get a corresponding bonus.</span></li>\n<li><span class=\"fontstyle0\">You can add the Intelligence modifier to all checks aimed at frightening or intimidating those in front of you.<br /></span></li>\n</ul>\n<p><span class=\"fontstyle0\">This ability can be used again after taking a long rest.</span> </p>",
      "chat": "",
      "unidentified": ""
    },
