  "system": {
    "description": {
      "value": "<p><span class=\"fontstyle0\">At 2nd level, you can use Channel Divinity to express a sentence of pure truth. With an action, you can wield your sacred symbol and every enemy of your faith within 30 feet perceives you as a supernatural force. In addition, each hostile creature within 30 feet must make a Constitution saving throw. If the creature fails, it takes 2d10 + your priest’s levels level of thundering damage, while if it is successful it takes only half that damage.<br /></span></p>\n<p><span class=\"fontstyle0\">A deafened creature or one in an area of magical silence still perceives your words and ignores immunity to thunder damage.</span> </p>",
      "chat": "",
      "unidentified": ""
    },
    "source": "HCB pg. 163",
